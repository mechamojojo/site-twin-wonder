DATABASE_URL="postgresql://postgres:postgres@localhost:5432/compraschina?schema=public"
PORT=4000

# Mercado Pago - Checkout Transparente (API Pagamentos)
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# CORS - origens permitidas (produção). Separe por vírgula.
# Ex: https://compraschina.com.br,https://www.compraschina.com.br,https://seu-projeto.vercel.app
CORS_ORIGINS=

# Admin - senha para acessar /admin (painel de pedidos). Obrigatório para a rota funcionar.
ADMIN_SECRET=sua-senha-secreta-aqui

# JWT - autenticação de clientes (crie uma string aleatória longa para produção)
JWT_SECRET=sua-chave-secreta-jwt-aqui

# Telegram - notificações de vendas (opcional)
# 1. Crie um bot com @BotFather no Telegram
# 2. Envie uma mensagem ao bot e acesse https://api.telegram.org/bot<TOKEN>/getUpdates para ver seu chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# URL do site (para link no Telegram e links de e-mail: confirmação, redefinir senha). Ex: https://compraschina.com.br
SITE_URL=

# URL pública do backend onde /uploads/... é servido (fotos do armazém nos e-mails). Se vazio, usa SITE_URL.
# Ex. produção: https://seu-app.up.railway.app  |  local: http://localhost:4000
API_PUBLIC_URL=

# ========== E-mail (confirmação de conta + recuperação de senha) ==========
# Resend: https://resend.com — crie uma API Key e use o domínio verificado ou onboarding@resend.dev em dev
RESEND_API_KEY=
EMAIL_FROM=ComprasChina <noreply@seudominio.com.br>

# ========== CAPTCHA (Cloudflare Turnstile) ==========
# https://dash.cloudflare.com → Turnstile — crie um site e use a Secret Key aqui
# No frontend use VITE_TURNSTILE_SITE_KEY com a Site Key
TURNSTILE_SECRET_KEY=
