# Mercado Pago - Chave pública (pagamento com cartão)
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
VITE_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# URL da API (produção - Railway). Em dev, deixe vazio para usar o proxy.
# Para compraschinatest.vercel.app use: https://site-twin-wonder-production.up.railway.app
VITE_API_URL=

# Cloudflare Turnstile - chave pública (cadastro e esqueci senha). Opcional.
# Obtenha em: https://dash.cloudflare.com → Turnstile
VITE_TURNSTILE_SITE_KEY=
